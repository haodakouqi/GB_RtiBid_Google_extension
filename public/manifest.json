{
   "name": "Shopera Pixel Helper",
   "short_name": "Shopera Pixel Helper",
   "version": "1.0.1",
   "manifest_version": 3,
   "description": "Shopera Pixel Helper",
   "background": {
      "service_worker": "background.js",
      "type": "module"
   },
   "action": {
      "default_title": "Shopera Pixel Helper",
      "default_popup": "index.html",
      "default_icon": {
         "16": "images/icon16.png",
         "32": "images/icon32.png",
         "48": "images/icon48.png",
         "128": "images/icon128.png"
      }
   },
   "icons": {
      "16": "images/icon16.png",
      "32": "images/icon32.png",
      "48": "images/icon48.png",
      "128": "images/icon128.png"
   },
   "permissions": [
      "storage",
      "activeTab",
      "webNavigation",
      "tabs",
      "webRequest"
   ],
   "host_permissions": ["<all_urls>"]
}